{
  "expo": {
    "name": "Martino Noir",
    "slug": "martinonoir",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo/splash-icon.png",
    "scheme": "martinonoir",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.martinonoir.mobile"
    },
    "android": {
      "package": "com.martinonoir.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [{ "scheme": "martinonoir" }]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/expo/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#0A0A0A",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.martinonoir.com/api/v1"
    }
  }
}
